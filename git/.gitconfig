# .gitconfig - Git configuration

[user]
	name = Peter N.
	email = peternutter100@gmail.com

[init]
	defaultBranch = main

[core]
	editor = vim
	autocrlf = input
	# Use delta if installed, fall back to less
	pager = delta --dark 2>/dev/null || less -FRX

[delta]
	navigate = true
	line-numbers = true
	side-by-side = false
	syntax-theme = ansi

[interactive]
	diffFilter = delta --color-only 2>/dev/null

[merge]
	conflictstyle = diff3

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[alias]
	s = status
	d = diff
	l = log --oneline -20
	lg = log --graph --oneline --decorate -20
	co = checkout
	br = branch
	cm = commit
	last = log -1 HEAD

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[color]
	ui = auto

[include]
	path = ~/.gitconfig.local
[safe]
	directory = *
