{
  "mcpServers": {
    "google_workspace": {
      "command": "uvx",
      "args": ["workspace-mcp", "--tools", "docs", "slides", "drive", "sheets", "calendar"],
      "env": {
        "GOOGLE_OAUTH_CLIENT_ID": "${GOOGLE_OAUTH_CLIENT_ID}",
        "GOOGLE_OAUTH_CLIENT_SECRET": "${GOOGLE_OAUTH_CLIENT_SECRET}",
        "MCP_SINGLE_USER_MODE": "1",
        "USER_GOOGLE_EMAIL": "peternutter100@gmail.com"
      }
    }
  }
}
