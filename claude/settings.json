{
  "env": {
    "EDITOR": "vim"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "acceptEdits"
  },
  "model": "opus",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(jq -r '.tool_input.file_path // empty') && [ -n \"$file\" ] && [[ \"$file\" == *.py ]] && uvx ruff check --fix --quiet \"$file\" 2>/dev/null; true"
          },
          {
            "type": "command",
            "command": "file=$(jq -r '.tool_input.file_path // empty'); [ -n \"$file\" ] && [[ \"$file\" == *.py ]] && { python3 -m py_compile \"$file\" || exit 2; }; exit 0"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": false,
    "context7@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "outputStyle": "custom",
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true,
  "vim": true,
  "remoteControlAtStartup": true
}
